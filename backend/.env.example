# Copy to backend/.env (git-ignored). All values optional.

# Enables the Scout/Analyst Claude agents. Without it the app runs in
# ungrounded mode (ratings from FIFA-rank priors).
ANTHROPIC_API_KEY=

# Overrides (defaults shown)
# CLAUDE_MODEL=claude-opus-4-8
# MONTE_CARLO_RUNS=10000
# DAILY_REFRESH_HOUR=6
# SCOUT_CONCURRENCY=6
# REFRESH_ON_STARTUP=true
